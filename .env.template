# Exchange selection: "bitkub" or "binance"
EXCHANGE=bitkub

# Bitkub Credentials
BITKUB_API_KEY=your_api_key_here
BITKUB_API_SECRET=your_api_secret_here
TRADE_AMOUNT_THB=100

# Binance Credentials (CCXT)
BINANCE_API_KEY=your_binance_key_here
BINANCE_API_SECRET=your_binance_secret_here
TRADE_AMOUNT=10 # Amount in quote currency (e.g., USDT for Binance, THB for Bitkub)

# Shared AI and Market Settings
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
TRADING_SYMBOL=BTC/THB # E.g., BTC/THB for Bitkub, or BTC/USDT for Binance
TIMEFRAME=1h
LOG_LEVEL=INFO
